{
  "name": "ojisan-invader-app",
  "version": "1.0.0",
  "description": "Retro-style browser game: Ojisan Invader - Middle-aged man vs. Cabaret girls",
  "type": "module",
  "main": "js/main.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "serve": "http-server -p 8080",
    "dev": "concurrently \"npm run serve\" \"npm run test:watch\""
  },
  "keywords": [
    "game",
    "canvas",
    "retro",
    "ecs",
    "javascript"
  ],
  "author": "Ojisan Invader Team",
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-canvas-mock": "^2.5.1",
    "@playwright/test": "^1.40.0",
    "concurrently": "^8.2.2",
    "http-server": "^14.1.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "jest-canvas-mock/lib/index.js",
      "./tests/setup.js"
    ],
    "transform": {},
    "extensionsToTreatAsEsm": [".js"],
    "moduleNameMapping": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.spec.js"
    ],
    "collectCoverageFrom": [
      "js/**/*.js",
      "!js/main.js",
      "!**/node_modules/**"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}